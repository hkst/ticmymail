{
  "": "http://json-schema.org/draft-07/schema#",
  "title": "tmm-part2 incident ingest",
  "type": "object",
  "required": [
    "schema_version",
    "event_type",
    "message_id",
    "thread_id",
    "subject",
    "body",
    "sender"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "v1"
    },
    "event_type": {
      "type": "string",
      "enum": [
        "new",
        "reply",
        "info_request",
        "workaround",
        "escalate",
        "status"
      ]
    },
    "message_id": {
      "type": "string"
    },
    "thread_id": {
      "type": "string"
    },
    "reported_at": {
      "type": "string",
      "format": "date-time"
    },
    "ingested_at": {
      "type": "string",
      "format": "date-time"
    },
    "subject": {
      "type": "string"
    },
    "body": {
      "type": "string"
    },
    "sender": {
      "type": "string"
    },
    "attachments": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "priority_hint": {
      "type": "string"
    },
    "correlation_hints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}